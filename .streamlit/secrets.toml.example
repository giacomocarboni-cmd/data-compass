# Data Compass — Streamlit secrets template
#
# USAGE
# -----
# Local development:
#   Copy this file to .streamlit/secrets.toml and fill in the values.
#   .streamlit/secrets.toml is already in .gitignore — do NOT commit it.
#
# Streamlit Community Cloud:
#   Paste the key=value pairs (without the [section] header) into the
#   "Secrets" text box in the app settings dashboard.
#
# IMPORTANT: review docs/PRIVACY_NOTICE.md and obtain legal sign-off before
# making the app publicly accessible.
# -----------------------------------------------------------------------

# Required: Anthropic API key used by the admin and recruiter tiers.
# Public visitors supply their own BYOK key — this one is NEVER sent to them.
ANTHROPIC_API_KEY = "sk-ant-api03-replace-me"

# Required: initial admin password. Data Compass seeds the admin account on
# first start using this value. Change it immediately after the first login.
# Leave blank ("") to skip admin seeding (no admin account created).
ADMIN_PASSWORD = "change-me-immediately"

# Optional — override defaults shown below:
# ADMIN_USERNAME               = "admin"
# ADMIN_PASSWORD_MAX_AGE_DAYS  = "30"
# RECRUITER_QUERY_CAP          = "20"
# RECRUITER_VALIDITY_DAYS      = "30"
# CACHE_THRESHOLD              = "0.8"
# CACHE_TOP_K                  = "3"
# FX_USD_TO_GBP                = "0.79"
