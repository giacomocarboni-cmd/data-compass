# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Owner's Anthropic API key (used for admin/recruiter tiers).
# Public users bring their own key via the UI — this is never exposed there.
ANTHROPIC_API_KEY=sk-ant-...

# Admin account seed (used on first run to create the admin user).
# Change immediately after first login. If left blank, no admin is seeded.
ADMIN_PASSWORD=change-me-on-first-run

# Admin login name (optional; defaults to "admin").
# ADMIN_USERNAME=admin

# Admin password renewal age, in days (optional; default 30).
# ADMIN_PASSWORD_MAX_AGE_DAYS=30

# Recruiter temporary-login limits (optional; defaults shown).
# RECRUITER_QUERY_CAP=20
# RECRUITER_VALIDITY_DAYS=30

# Cache-reuse confidence threshold (0.0–1.0). Default: 0.8
# CACHE_THRESHOLD=0.8
